{
  "name": "@glovebox.md/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "CLOUDFLARE_ENV=dev portless api.glovebox vp dev",
    "build": "vp build",
    "deploy": "vp run build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply glovebox-db --local --env dev",
    "db:migrate:remote": "wrangler d1 migrations apply glovebox-db --remote",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@better-auth/api-key": "catalog:",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@comark/react": "catalog:",
    "@glovebox.md/api": "workspace:*",
    "@glovebox.md/core": "workspace:*",
    "@glovebox.md/loro-codemirror": "workspace:*",
    "@glovebox.md/sync": "workspace:*",
    "@orpc/json-schema": "catalog:",
    "@orpc/openapi": "catalog:",
    "@orpc/server": "catalog:",
    "@orpc/zod": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-start": "catalog:",
    "beautiful-mermaid": "catalog:",
    "better-auth": "catalog:",
    "codemirror": "^6.0.2",
    "comark": "catalog:",
    "drizzle-orm": "catalog:",
    "loro-crdt": "^1.12.1",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@better-auth/memory-adapter": "catalog:",
    "@cloudflare/vite-plugin": "catalog:",
    "@cloudflare/workers-types": "catalog:",
    "@orpc/contract": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "drizzle-kit": "catalog:",
    "portless": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
